# ── Quantara Hardhat / BSC deployment ───────────────────────────────────────
# Copy to .env and fill values. Never commit real private keys.

# Local Hardhat JSON-RPC (default for npm run deploy)
BLOCKCHAIN_RPC=http://127.0.0.1:8545

# BNB Smart Chain RPCs
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/
BSC_RPC_URL=https://bsc-dataseed.binance.org/

# Deployer key (required for bsc / bscTestnet). Leave empty for localhost default accounts.
PRIVATE_KEY=

# Optional: expected chain id check during deploy (56 | 97 | 31337)
CHAIN_ID=

# Production / testnet BEP-20 payment token (USDT, USDC, custom, WBTC, WBNB, …).
# When set, MockBTCB is NOT deployed — contracts use this address.
# Leave empty on localhost to auto-deploy MockBTCB for QA.
TOKEN_ADDRESS=

# Price feed:
# - Localhost with no TOKEN_ADDRESS → MockBTCPriceFeed is deployed automatically
# - BSC: set CHAINLINK_BTC_USD (aggregator) to deploy ChainlinkBTCPriceFeed adapter
# - Or set PRICE_FEED_ADDRESS to an existing IBTCPriceFeed-compatible contract
#
# Known Chainlink BTC/USD aggregators (verify before mainnet use):
#   BSC Mainnet:  0x264990fbd0A4796A3BE9d60A1AC48F2399DF4EBd
#   BSC Testnet:  0x5741306c21795FdCBb9b265Ea0255F499DFe515C
CHAINLINK_BTC_USD=
PRICE_FEED_ADDRESS=

# Optional: recorded in deployed-addresses.json (treasury contract is still deployed)
TREASURY_WALLET=
