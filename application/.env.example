APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Quantara Web3 / BNB Smart Chain (BEP-20)
#
# Local Hardhat example:
BLOCKCHAIN_RPC=http://127.0.0.1:8545
BLOCKCHAIN_CHAIN_ID=31337
#
# BSC Testnet example:
# BLOCKCHAIN_RPC=https://data-seed-prebsc-1-s1.binance.org:8545/
# BLOCKCHAIN_CHAIN_ID=97
# BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/
#
# BSC Mainnet example:
# BLOCKCHAIN_RPC=https://bsc-dataseed.binance.org/
# BLOCKCHAIN_CHAIN_ID=56
# BSC_RPC_URL=https://bsc-dataseed.binance.org/
# CHAIN_ID=56
#
# Payment token (any BEP-20). TOKEN_ADDRESS is an alias for TOKEN_CONTRACT.
# TOKEN_ADDRESS=
TOKEN_CONTRACT=0x5FbDB2315678afecb367f032d93F642f64180aa3
CORE_CONTRACT=0xDc64a140Aa3E981100a9becA4E685f962f0cF6C9
TREASURY_CONTRACT=0xCf7Ed3AccA5a467e9e704C703E8D87F634fB0Fc9
REWARD_CONTRACT=0x5FC8d32690cc91D4c39d9d3abcBD16989F875707
# Optional — improves income indexer log filters (from deployed-addresses.json):
INCOME_CONTRACT=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0
CONTRIBUTION_CONTRACT=0x0165878A594ca255338adfa4d48449f69242Eb8F
BOOSTER_CONTRACT=0xa513E6E4b8f2a923D98304ec87F64353C4D5C853
RANK_CONTRACT=0x2279B7A0a67DB372996a5FaB50D91eAA73d2eBe6
COMMUNITY_CONTRACT=0x8A791620dd6260079BF849Dc5567aDC3F2FdC318

# IMPORTANT (local Hardhat):
# CORE_CONTRACT must be BTCPlanCore — NOT IncomeManager.
# After every fresh `npx hardhat node`, run:
#   cd smart-contracts && npm run bootstrap:demo
# which redeploys (if needed) and syncs these addresses automatically.

# Optional: expose APP_URL to Vite builds (subdirectory installs).
# Prefer Laravel boot baseUrl / #basePath; this is a fallback only.
# Example local: VITE_APP_URL=http://localhost/btc
VITE_APP_URL="${APP_URL}"
